CREATE TABLE Stud_Marks (
    Roll NUMBER,
    Name VARCHAR2(30),
    Total_Marks NUMBER
);

CREATE TABLE Result (
    Roll NUMBER,
    Name VARCHAR2(30),
    Class VARCHAR2(30)
);

CREATE OR REPLACE FUNCTION func_Grade (p_marks NUMBER)
RETURN VARCHAR2
IS
    v_class VARCHAR2(30);
BEGIN
    IF p_marks >= 990 AND p_marks <= 1500 THEN
        v_class := 'Distinction';

    ELSIF p_marks >= 900 AND p_marks <= 989 THEN
        v_class := 'First Class';

    ELSIF p_marks >= 825 AND p_marks <= 899 THEN
        v_class := 'Higher Second Class';

    ELSE
        v_class := 'Fail';
    END IF;

    RETURN v_class;
END;
/


SET SERVEROUTPUT ON;

DECLARE
    CURSOR c1 IS
        SELECT Roll, Name, Total_Marks FROM Stud_Marks;

    v_roll Stud_Marks.Roll%TYPE;
    v_name Stud_Marks.Name%TYPE;
    v_marks Stud_Marks.Total_Marks%TYPE;
    v_class VARCHAR2(30);

BEGIN
    OPEN c1;

    LOOP
        FETCH c1 INTO v_roll, v_name, v_marks;
        EXIT WHEN c1%NOTFOUND;

        -- Call function
        v_class := func_Grade(v_marks);

        -- Insert result
        INSERT INTO Result VALUES (v_roll, v_name, v_class);

        DBMS_OUTPUT.PUT_LINE(v_name || ' -> ' || v_class);

    END LOOP;

    CLOSE c1;
    COMMIT;

END;
/

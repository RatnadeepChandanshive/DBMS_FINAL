set serveroutput on;

declare
    v_roll borrower.rollin%type;
    v_book borrower.nameofbook%type;
    v_issue_date borrower.dateofissue%type;
    v_days number;
    v_fine number := 0;

begin
    -- accept input
    v_roll := &enter_roll_no;
    v_book := '&enter_book_name';

    -- get issue date
    select dateofissue into v_issue_date
    from borrower
    where rollin = v_roll and nameofbook = v_book;

    -- calculate days
    v_days := sysdate - v_issue_date;

    dbms_output.put_line('days: ' || v_days);

    -- fine calculation
    if v_days > 15 and v_days <= 30 then
        v_fine := v_days * 5;

    elsif v_days > 30 then
        v_fine := (30 * 5) + ((v_days - 30) * 50);

    else
        v_fine := 0;
    end if;

    dbms_output.put_line('fine amount: ' || v_fine);

    -- update status (i → r)
    update borrower
    set status = 'r'
    where rollin = v_roll;

    -- insert into fine table if fine exists
    if v_fine > 0 then
        insert into fine values (v_roll, sysdate, v_fine);
    end if;

    commit;

exception
    when no_data_found then
        dbms_output.put_line('record not found');

    when others then
        dbms_output.put_line('error: ' || sqlerrm);
end;

CREATE TABLE Stud_Marks (
    Roll NUMBER,
    Name VARCHAR2(30),
    Total_Marks NUMBER
);

CREATE TABLE Result (
    Roll NUMBER,
    Name VARCHAR2(30),
    Class VARCHAR2(30)
);

